{
  "name": "ngx-worker-bridge",
  "version": "0.1.0",
  "description": "Zero-boilerplate reactive bridge for Angular Dedicated and Shared Workers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.mjs",
      "require": "./dist/angular/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/angular/index.ts src/react/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/angular/index.ts src/react/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "angular",
    "react",
    "webworker",
    "sharedworker",
    "rxjs",
    "signals"
  ],
  "author": "yashwantyashu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yashwantyashu/worker-bridge.git"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "react": ">=16.8.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/core": "^18.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  }
}
